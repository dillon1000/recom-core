{
  "name": "recom-core-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:build": "wasm-pack build . --target web --release --no-pack --out-dir web/src/wasm --out-name recom_core",
    "dev": "pnpm wasm:build && vite --config vite.config.ts",
    "build": "pnpm wasm:build && tsc -b && vite build --config vite.config.ts",
    "test": "vitest run",
    "check": "cargo test && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "apache-arrow": "^21.1.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
